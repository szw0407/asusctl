msgid "Enable Tuning"
msgstr "Activer le réglage"

#: rog-control-center/ui/pages/system.slint:369
msgctxt "requires_fan_curve_warning"
msgid "CPU power limits require an active custom fan curve."
msgstr ""
"Les limites la puissance du CPU nécessitent une courbe de ventilation "
"personnalisée active."

#: rog-control-center/ui/pages/system.slint:334
#: rog-control-center/ui/pages/system.slint:335
msgctxt "ppt_pl1_spl"
msgid "CPU Sustained Power Limit"
msgstr "Limite la puissance soutenue du CPU"

#: rog-control-center/ui/pages/system.slint:336
msgctxt "ppt_pl1_spl_help"
msgid ""
"Long-term CPU power limit that affects sustained workload performance. "
"Higher values may increase heat and power consumption."
msgstr ""
"Limite la puissance du CPU à long terme qui affecte les performances "
"soutenues en charge de travail. Des valeurs plus élevées peuvent augmenter "
"la chaleur et la consommation d'énergie."

#: rog-control-center/ui/pages/system.slint:352
#: rog-control-center/ui/pages/system.slint:353
msgctxt "ppt_pl2_sppt"
msgid "CPU Turbo Power Limit"
msgstr "Limite la puissance Turbo du CPU"

#: rog-control-center/ui/pages/system.slint:354
msgctxt "ppt_pl2_sppt_help"
msgid ""
"Short-term CPU power limit for boost periods. Controls maximum power during "
"brief high-performance bursts."
msgstr ""
"Limite la puissance du CPU à court terme pour les périodes de boost. "
"Contrôle la puissance maximale pendant de brèves rafales à haute performance."

#: rog-control-center/ui/pages/system.slint:370
#: rog-control-center/ui/pages/system.slint:371
msgctxt "ppt_pl3_fppt"
msgid "CPU Fast Burst Power Limit"
msgstr "Limite la puissance de rafale rapide du CPU"

#: rog-control-center/ui/pages/system.slint:372
msgctxt "ppt_pl3_fppt_help"
msgid ""
"Ultra-short duration power limit for instantaneous CPU bursts. Affects "
"responsiveness during sudden workload spikes."
msgstr ""
"Limite la puissance de durée ultra-courte pour les salves instantanées du "
"CPU. Affecte la réactivité lors de pics soudains de charge de travail."

#: rog-control-center/ui/pages/system.slint:387
#: rog-control-center/ui/pages/system.slint:388
msgctxt "ppt_fppt"
msgid "Fast Package Power Limit"
msgstr "Limite la puissance du package rapide"

#: rog-control-center/ui/pages/system.slint:389
msgctxt "ppt_fppt_help"
msgid ""
"Ultra-short duration power limit for system package. Controls maximum power "
"during millisecond-scale load spikes."
msgstr ""
"Limite la puissance de durée ultra-courte pour le package système. Contrôle "
"la puissance maximale pendant les pics de charge à l’échelle de la "
"milliseconde."

#: rog-control-center/ui/pages/system.slint:405
#: rog-control-center/ui/pages/system.slint:406
msgctxt "ppt_apu_sppt"
msgid "APU Sustained Power Limit"
msgstr "Limite la puissance soutenue de l'APU"

#: rog-control-center/ui/pages/system.slint:407
msgctxt "ppt_apu_sppt_help"
msgid ""
"Long-term power limit for integrated graphics and CPU combined. Affects "
"sustained performance of APU-based workloads."
msgstr ""
"Limite la puissance à long terme pour les graphiques intégrés et le CPU "
"combinés. Affecte les performances durables des charges de travail basées "
"sur APU."

#: rog-control-center/ui/pages/system.slint:423
#: rog-control-center/ui/pages/system.slint:424
msgctxt "ppt_platform_sppt"
msgid "Platform Sustained Power Limit"
msgstr "Limite la puissance soutenue de la plate-forme"

#: rog-control-center/ui/pages/system.slint:425
msgctxt "ppt_platform_sppt_help"
msgid ""
"Overall system power limit for sustained operations. Controls total platform "
"power consumption over extended periods."
msgstr ""
"Limite la puissance globale du système pour des opérations soutenues. "
"Contrôle la consommation électrique totale de la plate-forme sur des "
"périodes prolongées."

#: rog-control-center/ui/pages/system.slint:441
#: rog-control-center/ui/pages/system.slint:442
msgctxt "nv_dynamic_boost"
msgid "GPU Power Boost"
msgstr "Augmentation de la puissance du GPU"

#: rog-control-center/ui/pages/system.slint:443
msgctxt "nv_dynamic_boost_help"
msgid ""
"Additional power allocation for GPU dynamic boost. Higher values increase "
"GPU performance but generate more heat."
msgstr ""
"Allocation de puissance supplémentaire pour l'amélioration dynamique du GPU. "
"Des valeurs plus élevées augmentent les performances du GPU mais génèrent "
"plus de chaleur."

#: rog-control-center/ui/pages/system.slint:459
#: rog-control-center/ui/pages/system.slint:460
msgctxt "nv_temp_target"
msgid "GPU Temperature Limit"
msgstr "Limite de température du GPU"

#: rog-control-center/ui/pages/system.slint:461
msgctxt "nv_temp_target_help"
msgid ""
"Maximum GPU temperature threshold in Celsius. GPU will throttle to maintain "
"temperature below this limit."
msgstr ""
"Seuil de température maximale du GPU en Celsius. Le GPU va accélérer pour "
"maintenir la température en dessous de cette limite."

